# Express Server Port
PORT=3000
NODE_ENV=development

# Database Configuration (MySQL for Drizzle, PostgreSQL for Prisma production)
DATABASE_URL=postgresql://user:password@localhost:5432/hexacv_db?schema=public
# For Drizzle (MySQL dev):
# DATABASE_URL=mysql://root:password@localhost:3306/hexacv_dev

# Cache configuration
REDIS_URL=redis://localhost:6379

# JWT secrets for local tokens
JWT_SECRET=your_jwt_secret_key_change_me_in_production

# Manus OAuth Setup
VITE_OAUTH_PORTAL_URL=https://auth.hexastacksolutions.com
VITE_APP_ID=hexacv_app_id
VITE_OWNER_OPEN_ID=admin-key-owner

# LLM Providers Configuration
OPENAI_API_KEY=sk-proj-...
DEEPSEEK_API_KEY=ds-...
GEMINI_API_KEY=your_gemini_key_1
GEMINI_API_KEY_2=your_gemini_key_2
GROK_API_KEY=your_grok_key

